{
  "name": "randomly-die",
  "version": "5.6.0",
  "description": "Random number generator with fast UI, dice, hex, binary and secrets",
  "productName": "Randomly/Die",
  "author": "Tim Middleton <x@vaults.ca>",
  "license": "GPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run",
    "deploy": "pnpm quasar build -m pwa && bash deploy.sh",
    "postinstall": "quasar prepare",
    "android:build": "pnpm quasar build && pnpm exec cap sync android && cd android && ./gradlew :app:assembleDebug",
    "android:build:release": "pnpm quasar build && pnpm exec cap sync android && cd android && ./gradlew :app:assembleRelease"
  },
  "dependencies": {
    "@quasar/extras": "^2.0.2",
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "quasar": "^2.21.0",
    "register-service-worker": "^1.7.2",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@quasar/app-vite": "3.0.0-rc.6",
    "@types/node": "^26.1.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-pursue": "^0.1.3",
    "workbox-build": "^7.4.1",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "engines": {
    "node": "^22 || ^24 || ^26 || ^28 || ^30",
    "npm": ">= 6.14.12",
    "yarn": ">= 1.21.1"
  }
}
